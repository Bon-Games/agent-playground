{
  "name": "gws-mcp",
  "source": "local",
  "port": 8100,
  "mcp_path": "/mcp",
  "description": "Google Workspace (Drive, Calendar, Gmail)",
  "environment": {
    "GEMINI_CLI_WORKSPACE_FORCE_FILE_STORAGE": "true",
    "PORT": "8100"
  },
  "volumes": [
    "gws-token:/opt/workspace"
  ],
  "command": [
    "node",
    "workspace-server/dist/index.js"
  ]
}