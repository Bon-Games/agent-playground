{
  "servers": [
    {
      "name": "unity-mcp",
      "repo": "https://github.com/CoplayDev/unity-mcp",
      "branch": "beta",
      "dockerfile": "Server/Dockerfile",
      "port": 8080,
      "mcp_path": "/mcp",
      "command": "--transport http --http-host 0.0.0.0 --http-port 8080"
    },
    {
      "name": "context7",
      "source": "local",
      "local_path": "dockerfiles/context7",
      "port": 3000,
      "mcp_path": "/mcp"
    },
    {
      "name": "mcp-discord",
      "source": "local",
      "local_path": "dockerfiles/mcp-discord",
      "port": 8085,
      "mcp_path": "/mcp",
      "environment": {
        "DISCORD_TOKEN": "${DISCORD_TOKEN}"
      }
    }
  ]
}